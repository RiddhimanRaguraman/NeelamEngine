<UserControl x:Class="NeelamEditor.Editors.ProjectLayoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NeelamEditor.Editors"
             xmlns:proj="clr-namespace:NeelamEditor.GameProject"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=proj:Project, IsDesignTimeCreatable=False}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Button Content="Add Scene" Width="96" VerticalAlignment="Center" Focusable="False"
                Grid.Row="0" HorizontalAlignment="Left" Margin="20,0,0,0"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding AddSceneCommand}"/>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Scenes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="{Binding IsActive, Mode=OneWay}"
                                  Expanded="OnScene_Expanded">
                            <Expander.Header>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"/>
                                        <!-- Remove scene -->
                                        <Button Content="Remove"
                                                Command="{Binding DataContext.RemoveSceneCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Margin="20,0" Focusable="False"/>
                                        <!-- Add an empty entity to this scene; only enabled when scene is active. -->
                                        <Button Content="Add Entity"
                                                Click="OnAddEntity_Button_Click"
                                                IsEnabled="{Binding IsActive}"
                                                Focusable="False"/>
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>
                            <!-- Game entities in this scene. SelectionChanged feeds the inspector. -->
                            <ListBox x:Name="entityList"
                                     ItemsSource="{Binding GameEntities}"
                                     IsEnabled="{Binding IsActive}"
                                     SelectionMode="Extended"
                                     SelectionChanged="OnGameEntity_ListBox_SelectionChanged"
                                     Height="160">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"/>
                                            <Button Content="X"
                                                    Margin="10,0,0,0"
                                                    Focusable="False"
                                                    Command="{Binding ParentScene.RemoveGameEntityCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
