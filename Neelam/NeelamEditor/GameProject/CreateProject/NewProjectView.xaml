<UserControl x:Class="NeelamEditor.GameProject.NewProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeelamEditor.GameProject"
             mc:Ignorable="d" Width="800"
             d:DataContext="{d:DesignInstance Type=local:NewProject, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{StaticResource SurfaceBrush}">
    <UserControl.DataContext>
        <local:NewProject/>
    </UserControl.DataContext>
    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ListBox Width="195" Height="280" ItemsSource="{Binding ProjectTemplates}" x:Name="templateListBox"
                     SelectedIndex="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Icon}" Width="48" Height="48" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ProjectType}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Width="400" Height="280" Margin="5,0,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding Path=SelectedItem.Screenshot, ElementName=templateListBox}"/>
                </Border.Background>
            </Border>
        </StackPanel>
        <Grid Margin="80,30,80,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center"
                       Margin="0,5,0,0"/>
            <TextBox   Grid.Row="1" Grid.Column="1"
                       Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,5,0,0"/>
            <Button    Grid.Row="1" Grid.Column="2" Content="Browse" Width="75"
                       Margin="5,5,0,0"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="OnBrowse_Button_Click"/>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,30,0,0">
            <Button Content="Create" Width="96" IsDefault="True" IsEnabled="{Binding IsValid}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnCreate_Button_Click"/>
            <Button Content="Exit" Width="96" Margin="30,0,0,0" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
        <TextBlock Text="{Binding ErrorMsg}" Margin="0,20,0,0"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource DangerBrush}"/>
    </StackPanel>
</UserControl>
