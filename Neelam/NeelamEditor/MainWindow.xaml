<Window x:Class="NeelamEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeelamEditor"
        xmlns:editors="clr-namespace:NeelamEditor.Editors"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Neelam Editor" Height="720" Width="1280"
        MinHeight="450" MinWidth="800"
        Background="{StaticResource SurfaceBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="{StaticResource BaseBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Neelam Editor"
                           Foreground="{StaticResource TextBrightBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <!-- Min / Max / Close. WindowChrome.IsHitTestVisibleInChrome makes
                     them clickable inside the otherwise drag-only caption area. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Width="46" Height="32"
                            Style="{StaticResource TitleBarButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnMinimize_Click"/>
                    <Button Content="◻" Width="46" Height="32"
                            Style="{StaticResource TitleBarButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnMaximize_Click"/>
                    <Button Content="X" Width="46" Height="32"
                            Style="{StaticResource CloseButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor body -->
        <editors:WorldEditorView Grid.Row="1"/>
    </Grid>
</Window>
